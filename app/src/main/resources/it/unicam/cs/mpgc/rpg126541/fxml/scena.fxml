<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.unicam.cs.mpgc.rpg126541.controller.ScenaController"
            prefWidth="1024" prefHeight="768">

    <!-- Header: titolo a sinistra, bottone salva a destra -->
    <top>
        <HBox styleClass="header-mappa" alignment="CENTER_LEFT" prefHeight="64" spacing="16">
            <VBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                <Label text="LEGGE DEL SILENZIO" styleClass="sottotitolo"/>
                <Label text="In missione" styleClass="testo-secondario"/>
            </VBox>
            <Button text="Salva Partita" onAction="#salvaPartita"/>
        </HBox>
    </top>

    <!-- Centro: testo narrativo + bottoni scelte -->
    <center>
        <VBox spacing="24" style="-fx-padding: 32px;">

            <!-- Pannello testo narrativo, scrollabile per testi lunghi -->
            <ScrollPane styleClass="scroll-pane" fitToWidth="true" VBox.vgrow="ALWAYS">
                <StackPane>
                    <!-- Sfondo della scena: dietro al testo narrativo; l'immagine viene sostituita dal controller in base al luogo della missione -->
                    <ImageView fx:id="imageSfondoScena" fitWidth="928" fitHeight="500" preserveRatio="true">
                        <image>
                            <Image url="@../immagini/sfondo_scena.png" backgroundLoading="true"/>
                        </image>
                    </ImageView>
                    <VBox styleClass="pannello-scena">
                        <Label fx:id="labelTestoScena" styleClass="testo-narrativo" wrapText="true"/>
                    </VBox>
                </StackPane>
            </ScrollPane>

            <!-- Bottoni delle scelte: generati dal controller in base alla scena corrente -->
            <VBox fx:id="pannelloScelte" spacing="12"/>

        </VBox>
    </center>

    <!-- Destra: pannello statistiche stile dossier criminale (uguale alla mappa) -->
    <right>
        <VBox styleClass="pannello-dossier" spacing="14" prefWidth="240" minWidth="240" maxWidth="240">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <ImageView fitWidth="80" fitHeight="120" preserveRatio="true">
                    <image>
                        <Image url="@../immagini/ritratto_salvatore.png" backgroundLoading="true"/>
                    </image>
                </ImageView>
                <VBox spacing="4">
                    <Label fx:id="labelNome" styleClass="nome-personaggio" wrapText="true"/>
                    <Label fx:id="labelRango" styleClass="etichetta-rango"/>
                </VBox>
            </HBox>

            <Region styleClass="separatore"/>

            <!-- RISPETTO -->
            <VBox spacing="4">
                <Label text="RISPETTO" styleClass="etichetta-stat"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <ProgressBar fx:id="barRispetto" prefWidth="160" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="valRispetto" styleClass="valore-stat"/>
                </HBox>
            </VBox>

            <!-- RICCHEZZA -->
            <VBox spacing="4">
                <Label text="RICCHEZZA" styleClass="etichetta-stat"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <ProgressBar fx:id="barRicchezza" prefWidth="160" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="valRicchezza" styleClass="valore-stat"/>
                </HBox>
            </VBox>

            <!-- ASTUZIA -->
            <VBox spacing="4">
                <Label text="ASTUZIA" styleClass="etichetta-stat"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <ProgressBar fx:id="barAstuzia" prefWidth="160" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="valAstuzia" styleClass="valore-stat"/>
                </HBox>
            </VBox>

            <!-- LEALTÀ -->
            <VBox spacing="4">
                <Label text="LEALTÀ" styleClass="etichetta-stat"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <ProgressBar fx:id="barLealta" prefWidth="160" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="valLealta" styleClass="valore-stat"/>
                </HBox>
            </VBox>

        </VBox>
    </right>

</BorderPane>
